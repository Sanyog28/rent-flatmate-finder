# ---- Server ----
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ---- Database ----
# Leave DATABASE_URL empty to use local SQLite file
# For Postgres: postgres://user:pass@host:5432/dbname
DATABASE_URL=
DB_SSL=false
DB_ALTER=true

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_secret_string

# ---- LLM (OpenAI) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Email (SMTP) ----
# Examples: Gmail, Brevo, Mailtrap, SendGrid
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@flatmatefinder.com

# Set true to email owner on EVERY interest (not just score > 80)
NOTIFY_ALL_INTERESTS=false

# ---- Seed data ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
